{
  "$schema": "http://json.schemastore.org/template",
  "author": "Bilel H",
  "classifications": [
    "Web",
    "API",
    "Clean Architecture",
    "ASP.NET Core"
  ],
  "identity": "DotnetApiTemplate.CleanArchitecture",
  "name": "Clean Architecture API Template",
  "shortName": "dotnet-api",
  "description": "A clean architecture ASP.NET Core API template with EF Core, FluentValidation, Serilog, Docker, and more.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "DotnetApiTemplate",
  "preferNameDirectory": true,
  "guids": [
    "d9f8b8f1-8c1a-4d5e-9f8b-8f18c1a4d5e9"
  ],
  "symbols": {
    "dbNameBase": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "alphanumericOnly"
    },
    "dbName": {
      "type": "derived",
      "valueSource": "dbNameBase",
      "valueTransform": "appendDb",
      "replaces": "DotnetApiTemplateDb"
    }
  },
  "forms": {
    "alphanumericOnly": {
      "identifier": "replace",
      "pattern": "[^A-Za-z0-9]",
      "replacement": ""
    },
    "appendDb": {
      "identifier": "replace",
      "pattern": "$",
      "replacement": "Db"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/.git/**",
            "**/node_modules/**",
            ".template.config/**"
          ]
        }
      ]
    }
  ]
}
