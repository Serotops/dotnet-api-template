{
  "$schema": "http://json.schemastore.org/template",
  "author": "DotnetApiTemplate",
  "classifications": [
    "Web",
    "API",
    "Clean Architecture",
    "ASP.NET Core"
  ],
  "identity": "DotnetApiTemplate.CleanArchitecture",
  "name": "Clean Architecture API Template",
  "shortName": "dotnet-api",
  "description": "A clean architecture ASP.NET Core API template with EF Core, FluentValidation, AutoMapper, Serilog, Docker, and more.",
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "DotnetApiTemplate",
  "preferNameDirectory": true,
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/.git/**",
            "**/node_modules/**",
            ".template.config/**"
          ]
        }
      ]
    }
  ]
}
